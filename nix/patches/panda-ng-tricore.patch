+
+class TriCoreArch(PandaArch):
+    '''
+    Register names and accessors for TriCore
+    '''
+
+    def __init__(self, panda):
+        super().__init__(panda)
+        self.registers = {f"D{i}": f"D{i}" for i in range(16)}
+        self.registers |= {f"A{i}": f"A{i}" for i in range(16)}
+        self.registers["SP"] = "A10"
+        self.registers["RA"] = "A11"
+        self.registers["LR"] = "A11"
+        self.registers["PC"] = "PC"
+        self.registers["PSW"] = "PSW"
+
+        self.reg_sp = "SP"
+        self.reg_retaddr = "RA"
+        self.call_conventions = {"tricore": ["D4", "D5", "D6", "D7"]}
+        self.call_conventions["default"] = self.call_conventions["tricore"]
+        self.reg_retval = {"default": "D2"}
+
+    def _get_reg_val(self, cpu, reg):
+        env = self.cpu_env(cpu)
+
+        if reg.startswith("D"):
+            return env.gpr_d[int(reg[1:])]
+        if reg.startswith("A"):
+            return env.gpr_a[int(reg[1:])]
+        if reg == "PC":
+            return env.PC
+        if reg == "PSW":
+            if hasattr(self.panda.libpanda, "psw_read"):
+                return self.panda.libpanda.psw_read(env)
+            return env.PSW
+        raise ValueError(f"Invalid register name {reg}")
+
+    def _set_reg_val(self, cpu, reg, val):
+        env = self.cpu_env(cpu)
+
+        if reg.startswith("D"):
+            env.gpr_d[int(reg[1:])] = val
+            return
+        if reg.startswith("A"):
+            env.gpr_a[int(reg[1:])] = val
+            return
+        if reg == "PC":
+            env.PC = val
+            return
+        if reg == "PSW":
+            if hasattr(self.panda.libpanda, "psw_write"):
+                self.panda.libpanda.psw_write(env, val)
+            else:
+                env.PSW = val
+            return
+        raise ValueError(f"Invalid register name {reg}")
+
+
