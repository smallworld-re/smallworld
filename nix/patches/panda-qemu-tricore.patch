# Temporary local PANDA/QEMU patch for SmallWorld's TriCore bring-up.
# It adds the missing TriCore target hooks SmallWorld needs today and skips the
# `qemu_plugin_get_hwaddr` path unless a physical-memory callback actually
# needs it. Remove once upstream PANDA/qemu carries equivalent TriCore support.
diff --git a/contrib/plugins/panda_plugin_interface.c b/contrib/plugins/panda_plugin_interface.c
--- a/contrib/plugins/panda_plugin_interface.c
+++ b/contrib/plugins/panda_plugin_interface.c
@@ -44,15 +44,18 @@
 static void vcpu_mem(unsigned int cpu_index, qemu_plugin_meminfo_t info,
                      uint64_t vaddr, void *udata){
     CPUState *cpu = panda_cpu_by_index(cpu_index);
+    unsigned tag = (info >> 16) & 0xff;
     uint64_t pc = (uint64_t)(uintptr_t)udata;
-    struct qemu_plugin_hwaddr* hwaddr_info = qemu_plugin_get_hwaddr(info, vaddr);
+    struct qemu_plugin_hwaddr* hwaddr_info = NULL;
+    if (tag & panda_get_phys_memcb_status()) {
+        hwaddr_info = qemu_plugin_get_hwaddr(info, vaddr);
+    }
     uint64_t hwaddr = -1;
     // fprintf(stderr, "vcpu_mem: cpu_index = %u info = %#" PRIx64 " vaddr = %#" PRIx64 " udata = %p\n", cpu_index, (uint64_t)info, vaddr, udata);
     if (hwaddr_info){
         hwaddr = qemu_plugin_hwaddr_phys_addr(hwaddr_info);
     }
     // enum qemu_plugin_mem_rw tag = get_plugin_meminfo_rw(info);
-    unsigned tag = (info >> 16) & 0xff;
     qemu_plugin_mem_value m = qemu_plugin_mem_get_value(info);
     size_t size;
     void *data;
diff --git a/include/panda/panda_qemu_plugin_helpers.h b/include/panda/panda_qemu_plugin_helpers.h
--- a/include/panda/panda_qemu_plugin_helpers.h
+++ b/include/panda/panda_qemu_plugin_helpers.h
@@ -1,4 +1,5 @@
 CPUState *panda_cpu_by_index(int index);
 CPUState *panda_cpu_in_translate(void);
 TranslationBlock *panda_get_tb(struct qemu_plugin_tb *tb);
-int panda_get_memcb_status(void);
\ No newline at end of file
+int panda_get_memcb_status(void);
+int panda_get_phys_memcb_status(void);
diff --git a/panda/src/common.c b/panda/src/common.c
--- a/panda/src/common.c
+++ b/panda/src/common.c
@@ -152,6 +152,8 @@
   #elif defined(TARGET_LOONGARCH)
     CPUArchState *env = cpu_env(cpu);
     return (env->CSR_ASID & 0xff);
+  #elif defined(TARGET_TRICORE)
+    return 0;
   #else
   #error "panda_current_asid() not implemented for target architecture."
     return 0;
diff --git a/panda/src/panda_arch.c b/panda/src/panda_arch.c
--- a/panda/src/panda_arch.c
+++ b/panda/src/panda_arch.c
@@ -31,6 +31,8 @@
     // Both supervisor (S) and machine (M) modes are considered kernel mode
     // Check the privilege bits in mstatus CSR
     return (env->priv >= PRV_S);
+#elif defined(TARGET_TRICORE)
+    return false;
 #else
 #error "panda_in_kernel_mode() not implemented for target architecture."
     return false;
@@ -148,6 +150,8 @@
     // For how stack works in RISC-V, see:
     // https://github.com/riscv/riscv-elf-psabi-doc/blob/master/riscv-elf.md
     return env->gpr[2];
+#elif defined(TARGET_TRICORE)
+    return env->gpr_a[10];
 #else
 #error "panda_current_ksp() not implemented for target architecture."
     return 0;
@@ -184,6 +188,8 @@
 #elif defined(TARGET_RISCV)
     // For RISC-V, stack pointer is x2/sp
     return env->gpr[2];
+#elif defined(TARGET_TRICORE)
+    return env->gpr_a[10];
 #else
 #error "panda_current_sp() not implemented for target architecture."
     return 0;
@@ -222,6 +228,8 @@
 #elif defined(TARGET_RISCV)
     // RISC-V uses a0 (x10) for return value
     return env->gpr[10];
+#elif defined(TARGET_TRICORE)
+    return env->gpr_d[2];
 #else
 #error "panda_get_retval() not implemented for target architecture."
     return 0;
@@ -248,6 +256,8 @@
 #elif defined(TARGET_RISCV)
     // RISC-V uses a0 (x10) for return value
     env->gpr[10] = value;
+#elif defined(TARGET_TRICORE)
+    env->gpr_d[2] = value;
 #else
 #error "panda_get_retval() not implemented for target architecture."
 #endif
@@ -290,6 +300,9 @@
     #define GPR(x) env->gpr[x]
                         // a7, a0    a1    a2    a3    a4    a5    a6
     target_ulong regs[] = {17, 10, 11, 12, 13, 14, 15, 16};
+#elif defined(TARGET_TRICORE)
+    #define GPR(x) env->gpr_d[x]
+    target_ulong regs[] = {2, 4, 5, 6, 7};
 
 #endif

