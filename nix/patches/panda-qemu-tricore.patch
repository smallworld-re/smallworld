+    if ((include_phys && panda_has_callback_registered(PANDA_CB_PHYS_MEM_AFTER_READ))
+    || (include_virt && panda_has_callback_registered(PANDA_CB_VIRT_MEM_AFTER_READ)))
     {
         rv |= QEMU_PLUGIN_AFTER_MEM_R;
