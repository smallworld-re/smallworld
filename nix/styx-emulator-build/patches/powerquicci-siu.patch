     fn name(&self) -> &str {
         "System Interface Unit"
     }
+
+    /// The SIU owns the decrementer, so it advertises that exception number.
+    fn irqs(&self) -> Vec<ExceptionNumber> {
+        vec![Mpc866mIRQn::Decrementer as ExceptionNumber]
+    }
+
+    /// Advance the timebase and decrementer once per stride. On decrementer
+    /// underflow, latch a Decrementer exception; the controller only delivers it
+    /// when the guest has enabled interrupts (MSR[EE]), so this is a no-op for
+    /// interrupt-disabled workloads.
+    fn tick(
+        &mut self,
+        _cpu: &mut dyn CpuBackend,
+        _mmu: &mut Mmu,
+        event_controller: &mut dyn EventControllerImpl,
+        delta: &Delta,
+    ) -> Result<(), UnknownError> {
+        let step = delta.count.min(u32::MAX as u64) as u32;
+        if self.mtspr_mgr.tick(step) {
+            let _ = event_controller.latch(Mpc866mIRQn::Decrementer as ExceptionNumber);
+        }
+        Ok(())
+    }
