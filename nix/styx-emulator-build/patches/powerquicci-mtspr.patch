+    /// Advance the 64-bit timebase by `step`, and (once the guest has programmed
+    /// it) decrement the decrementer by `step`. Returns `true` if the
+    /// decrementer underflowed, meaning the caller should latch a Decrementer
+    /// exception. Called from the SIU peripheral tick with the elapsed
+    /// instruction count for the stride.
+    pub(crate) fn tick(&mut self, step: u32) -> bool {
+        // The timebase always runs.
+        let tb = (((self.tbuw as u64) << 32) | self.tblw as u64).wrapping_add(step as u64);
+        self.tblw = tb as u32;
+        self.tbuw = (tb >> 32) as u32;
+
+        if !self.dec_active {
+            return false;
+        }
+
+        match self.dec.checked_sub(step) {
+            Some(remaining) => {
+                self.dec = remaining;
+                false
+            }
+            None => {
+                self.dec = self.dec_reload;
+                true
+            }
         }
     }
 }
 
